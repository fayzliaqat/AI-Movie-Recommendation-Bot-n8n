              "id": "e4818050-7b06-4c9a-afe2-3d5ce27268fc",
              "name": "=geminiPrompt",
              "value": "={{ \"You are an expert movie recommendation assistant. The user's mood is: '\" + $json.cleanMood + \"'. Recommend exactly 3 movies that perfectly match this mood. Format your response as clean, plain text without any special characters like asterisks, hashtags, or markdown symbols. Structure it like this:\\n\\nMovie 1:\\nTitle: [Movie Name] (Year)\\nWhy watch: [2-3 engaging sentences explaining why this movie fits the mood]\\n\\nMovie 2:\\nTitle: [Movie Name] (Year)\\nWhy watch: [2-3 engaging sentences]\\n\\nMovie 3:\\nTitle: [Movie Name] (Year)\\nWhy watch: [2-3 engaging sentences]\\n\\nMake your descriptions warm, engaging, and easy to read. Use simple line breaks for structure.\" }}\n",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        544,
        -224
      ],
      "id": "4304704f-5e01-4d26-af2c-d8f1af288534",
      "name": "📝 Build Gemini Prompt"
    },
    {
      "parameters": {
        "jsCode": "// Get the prompt from previous node\nconst prompt = $input.item.json.geminiPrompt;\n\n// Build the request body\nconst requestBody = {\n  contents: [{\n    parts: [{\n      text: prompt\n    }]\n  }]\n};\n\n// Return it\nreturn { json: { requestBody: requestBody, geminiPrompt: prompt } };\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        -224
      ],
      "id": "3932c6e5-cf30-436c-baa1-ff6ed565dad2",
      "name": "🔧 Prepare API Request Body"
    },
